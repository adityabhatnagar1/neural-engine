":1},"end":{"line":14,"column":1}},"children":[{"type":"text","value":"Every spike-based computing system is, at some level of abstraction, an engineering approximation of biological neural circuits. Understanding what is being approximated — and what is being discarded — is essential for evaluating what neuromorphic hardware can and cannot do. The rules governing synaptic plasticity, discovered in biological systems, directly inspire the learning rules implemented in neuromorphic devices.","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"eSYSf1TjUy"}],"key":"pSgtrxYfkI"},{"type":"heading","depth":2,"position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"text","value":"Core concepts","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"vfyzYJXfdB"}],"identifier":"core-concepts","label":"Core concepts","html_id":"core-concepts","implicit":true,"key":"tkVvdj6ZQ0"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":18,"column":1},"end":{"line":24,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"text","value":"Chemical synapse structure","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"wO4Dt6Q2FS"}],"key":"e1DwVLypg5"},{"type":"text","value":" — presynaptic terminal, synaptic cleft, postsynaptic density, neurotransmitter vesicle release","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"EJiKivj1oc"}],"key":"fgJTGdfP0I"}],"key":"t5fCGcWtI8"},{"type":"listItem","spread":true,"position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":19,"column":1},"end":{"line":