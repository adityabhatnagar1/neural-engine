{"version":3,"kind":"Article","sha256":"b123e4630e753d0eb6cef3320b678b455c9f1838bf18b1d677d920fbd2854e9b","slug":"plasticity.index","location":"/plasticity/index.md","dependencies":[],"frontmatter":{"title":"Plasticity","description":"Synaptic plasticity rules — STDP, BCM theory, metaplasticity, rate-based and timing-based learning.","content_includes_title":false,"exports":[{"format":"md","filename":"index.md","url":"/index-5b4d37273c56fd2ccc7e2fef8bdf1194.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"What is this domain?","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"OqKZOL3yTW"}],"identifier":"what-is-this-domain","label":"What is this domain?","html_id":"what-is-this-domain","implicit":true,"key":"xBR9j58Lgy"},{"type":"paragraph","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"Synaptic plasticity encompasses the mechanisms by which the strength of synaptic connections changes in response to neural activity. These changes can occur on timescales from milliseconds (short-term plasticity) to hours and days (long-term potentiation and depression), and they constitute the primary substrate for learning and memory in the brain. Plasticity rules specify the conditions under which a synapse is strengthened or weakened.","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"L802qpxYyT"}],"key":"J5eDuvJQPn"},{"type":"heading","depth":2,"position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"text","value":"Why it matters","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"j4gIwlsAx4"}],"identifier":"why-it-matters","label":"Why it matters","html_id":"why-it-matters","implicit":true,"key":"gOMvZl77JE"},{"type":"paragraph","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"text","value":"Plasticity rules are the learning algorithms of the brain. They are the biological counterpart of gradient descent in deep learning, and understanding them is essential for designing hardware that can learn autonomously from data without relying on offline training. Implementing spike-timing-dependent plasticity (STDP) or related rules in memristive devices is one of the central challenges of neuromorphic engineering.","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"S2Ika8e0TM"}],"key":"RbjkEYWxop"},{"type":"heading","depth":2,"position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"text","value":"Core concepts","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"lEHqtf4Lbu"}],"identifier":"core-concepts","label":"Core concepts","html_id":"core-concepts","implicit":true,"key":"vZQ6yC2MFM"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":18,"column":1},"end":{"line":24,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"text","value":"Spike-timing-dependent plasticity (STDP)","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"OiYQL5YrYv"}],"key":"Nn2BlGdqyZ"},{"type":"text","value":" — synaptic weight changes depend on the precise relative timing of pre- and postsynaptic spikes; causal (pre before post) firing potentiates, anticausal (post before pre) depresses","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"KVjkvPHvsS"}],"key":"dXCCjeVoIe"}],"key":"hxRhSJfGiq"},{"type":"listItem","spread":true,"position":{"start":{"line":19,"column":1},"end":{"line":19,"column"