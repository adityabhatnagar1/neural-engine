{"version":3,"kind":"Article","sha256":"552e6bb5a4a459cdc354b2345d07a4a7ce5a5646867c882399e4d007ef809a11","slug":"neuron-models.index","location":"/neuron-models/index.md","dependencies":[],"frontmatter":{"title":"Neuron Models","description":"Computational models of neurons — Hodgkin-Huxley, integrate-and-fire, FitzHugh-Nagumo, AdEx, Izhikevich, and dendritic computation.","content_includes_title":false,"exports":[{"format":"md","filename":"index.md","url":"/index-b066ca5932024d1f4aea3a8d9b201756.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"What is this domain?","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"wvYzUN3Wn7"}],"identifier":"what-is-this-domain","label":"What is this domain?","html_id":"what-is-this-domain","implicit":true,"key":"bfqkET8Wwd"},{"type":"paragraph","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"Neuron models are mathematical descriptions of the electrical dynamics of individual neurons. They range from biophysically detailed conductance-based models that reproduce the full ionic basis of the action potential, to highly abstracted point neuron models that retain only the spike threshold and reset mechanism. Each model represents a different trade-off between biological fidelity, computational tractability, and analytical transparency.","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"owal7mvecm"}],"key":"BZM971Kj4X"},{"type":"heading","depth":2,"position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"text","value":"Why it matters","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"glyPfqMXg8"}],"identifier":"why-it-matters","label":"Why it matters","html_id":"why-it-matters","implicit":true,"key":"iUsch71FA4"},{"type":"paragraph","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"text","value":"Neuron models are the building blocks of any spiking neural network. The choice of model determines what dynamics are preserved in simulation, what hardware resources are required, and what learning rules can be applied. For neuromorphic hardware designers, neuron models define the computation that silicon circuits must implement; for theorists, they define the dynamical systems whose behaviour must be understood.","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"hDnkJce0LF"}],"key":"c9FHqcGsFK"},{"type":"heading","depth":2,"position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"text","value":"Core concepts","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"oUL6xjYqNy"}],"identifier":"core-concepts","label":"Core concepts","html_id":"core-concepts","implicit":true,"key":"Q052SvJG4a"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":18,"column":1},"end":{"line":24,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"text","value":"Hodgkin-Huxley model","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"xmyujgrSeV"}],"key":"XIqTIdpOd4"},{"type":"text","value":" — four coupled ODEs describing the dynamics of sodium, potassium, and leak conductances; the canonical biophysical neuron model","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"S8QyzOPbNe"}],"key":"yHh0D4wTt3"}],"key":"jAIhonY4Qk"},{"type":"listItem","spread":true,"position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"parag